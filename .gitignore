# ============================================================
#   AceStep-Portable-Scripts — .gitignore
# ============================================================

# --- НЕ коммитим тяжёлые/генерируемые файлы ---
models/
python-*/
repo/
data/
output/
logs/
*.log
*.wav
*.mp3
*.safetensors
*.bin
*.ckpt
*.pth

# --- Windows ---
*.exe
*.dll
*.zip
*.7z

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# --- IDE ---
.vs/
.vscode/
.idea/
*.sln
*.pyproj
*.user

# --- Пользовательские настройки (генерируются автоматом) ---
scripts/Config.ini
.env
